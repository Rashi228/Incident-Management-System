# Supabase connection string format: postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ims
SECRET_KEY=super-secret-jwt-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
GCP_PROJECT_ID=incident-management-project
GCP_BUCKET_NAME=incident-management-storage
